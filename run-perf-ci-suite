"""Thin entry for the Clusterbuster CI suite; implementation is in ``lib.clusterbuster.ci.run_perf``.

AI-assisted tooling (Cursor Agent).
"""

from __future__ import annotations

import os
import sys

# Same mechanism as clusterbuster-report / analyze-clusterbuster-report: optional
# CB_LIBPATH (colon-separated) is prepended to sys.path. The script directory is
# already on sys.path, so ``from lib.clusterbuster...`` resolves without PYTHONPATH=lib.
if "CB_LIBPATH" in os.environ:
    sys.path = [element for element in os.environ["CB_LIBPATH"].split(":")] + sys.path

from lib.clusterbuster.ci.run_perf import main

if __name__ == "__main__":
    raise SystemExit(main())
