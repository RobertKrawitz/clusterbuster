"""Clusterbuster CI perf suite launcher.

Imports ``lib.clusterbuster`` the same way as ``clusterbuster-report``: optional
``CB_LIBPATH`` (colon-separated) is prepended to ``sys.path`` **before** the
``from lib.clusterbuster…`` import so extra library roots take effect.

Logging: :func:`clusterbuster.ci.run_perf.main` configures the ``clusterbuster.ci``
logger tree so routine messages go to **stdout** and warnings/errors to **stderr**
(see :mod:`clusterbuster.ci.logging_config`).
"""

from __future__ import annotations

import os
import signal
import sys

signal.signal(signal.SIGINT, lambda *_: sys.exit(130))
signal.signal(signal.SIGPIPE, signal.SIG_DFL)

if "CB_LIBPATH" in os.environ:
    sys.path = [element for element in os.environ["CB_LIBPATH"].split(":")] + sys.path

from lib.clusterbuster.ci.run_perf import main

if __name__ == "__main__":
    raise SystemExit(main())
