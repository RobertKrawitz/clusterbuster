import sys
from pathlib import Path


def _run() -> int:
    repo = Path(__file__).resolve().parents[2]
    sys.path.insert(0, str(repo / "tests" / "workload-options"))
    from workload_options.repeat import main

    return main()


if __name__ == "__main__":
    raise SystemExit(_run())
