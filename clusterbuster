"""ClusterBuster — Python driver launcher.

Discovers the lib/ directory relative to the script location,
adds it to sys.path, and delegates to clusterbuster.driver.main().
"""

import os
import signal
import sys


def _main() -> None:
    signal.signal(signal.SIGINT, lambda *_: sys.exit(130))
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)

    script_dir = os.path.dirname(os.path.realpath(__file__))
    lib_path = os.environ.get("CB_LIBPATH", os.path.join(script_dir, "lib"))
    if lib_path not in sys.path:
        sys.path.insert(0, lib_path)

    from clusterbuster.driver import main
    main()


if __name__ == "__main__":
    _main()
